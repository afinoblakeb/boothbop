# BoothBop release automation. The lanes are deliberately staged so candidate
# creation cannot accidentally upload or submit the app.

opt_out_usage
default_platform(:ios)

def asc_key
  app_store_connect_api_key(
    key_id: ENV.fetch("APPCONNECT_KEY_ID"),
    issuer_id: ENV.fetch("APPCONNECT_ISSUER_ID"),
    key_filepath: ENV.fetch("APPCONNECT_KEY_PATH"),
    in_house: false,
  )
end

platform :ios do
  desc "Run every local web and native release gate"
  lane :verify do
    sh("cd .. && npm run check:all")
    sh("cd .. && npm run ios:smoke")
  end

  desc "Build the production web app and copy it into the iOS project"
  lane :prepare do
    sh("cd .. && npm run ios:sync")
  end

  desc "Verify and export a signed local App Store candidate without uploading"
  lane :candidate do
    verify
    prepare
    gym(
      project: "../ios/App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "../build",
      output_name: "BoothBop-0.1.0-3.ipa",
      clean: true,
    )
  end

  desc "Build the verified candidate and upload it to TestFlight"
  lane :beta do
    key = asc_key
    candidate
    pilot(api_key: key, skip_waiting_for_build_processing: true)
  end

  desc "Push listing metadata and screenshots without uploading a binary"
  lane :metadata do
    deliver(
      api_key: asc_key,
      skip_binary_upload: true,
      submit_for_review: false,
      force: true,
    )
  end

  desc "Submit the App Store Connect version that is already configured"
  lane :submit do
    unless ENV["CONFIRM_APP_STORE_SUBMISSION"] == "YES"
      UI.user_error!(
        "Submission blocked. Set CONFIRM_APP_STORE_SUBMISSION=YES after physical-device review.",
      )
    end

    deliver(
      api_key: asc_key,
      skip_binary_upload: true,
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      run_precheck_before_submit: false,
      submission_information: {
        export_compliance_uses_encryption: false,
        add_id_info_uses_idfa: false,
      },
    )
  end
end
