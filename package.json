{
  "name": "boothbop",
  "private": true,
  "version": "0.0.4",
  "type": "module",
  "description": "Turn your phone into a selfie photo booth — 4 photos back to back, then a strip, GIF, or video.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:demo": "tsc -b && VITE_DEMO=1 vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "env -u NO_COLOR -u FORCE_COLOR playwright test",
    "check:e2e": "npm run test:e2e",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "gen:assets": "node scripts/gen-assets.mjs",
    "ios:sync": "npm run build && npx cap sync ios",
    "ios:smoke": "node scripts/ios-smoke.mjs",
    "ios:bopfx:fixture": "node scripts/ios-bopfx-fixture.mjs",
    "ios:swift:lint": "xcrun swift-format lint --strict --recursive ios/CameraCore ios/App/App/BopFXLivingCaptureBuffer.swift",
    "ios:camera-core:test": "swift test --package-path ios/CameraCore",
    "ios:open": "npx cap open ios",
    "ios": "npm run ios:sync && npm run ios:open",
    "gen:cap-assets": "node scripts/gen-capacitor-assets.mjs",
    "appstore": "node scripts/app-store.mjs",
    "appstore:status": "node scripts/app-store.mjs status",
    "appstore:screenshots": "node scripts/app-store-screenshots.mjs",
    "appstore:screenshots:upload": "node scripts/upload-app-store-screenshots.mjs"
  },
  "dependencies": {
    "@capacitor/browser": "^8.0.3",
    "@capacitor/core": "^8.4.1",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/share": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@fontsource/bebas-neue": "^5.2.7",
    "@fontsource/oswald": "^5.2.8",
    "gifenc": "^1.0.3",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9"
  }
}
